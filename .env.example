# ==============================================================
# TaxReport Pro — шаблон переменных окружения
# Скопируйте в .env и заполните значения
# НИКОГДА не коммитьте .env в git!
# ==============================================================

# ── Приложение ─────────────────────────────────────────────────
APP_ENV=production                        # production | development
APP_DEBUG=false
APP_DOMAIN=taxrep.finitin.us
APP_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── База данных PostgreSQL ──────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=taxreportpro
POSTGRES_USER=taxreport_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Telegram авторизация ────────────────────────────────────────
# Получить у @BotFather: /newbot → /setdomain taxrep.finitin.us
TELEGRAM_BOT_TOKEN=CHANGE_ME_your_bot_token
TELEGRAM_BOT_USERNAME=CHANGE_ME_YourBotUsername

# ── JWT ─────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Шифрование чувствительных данных (AES-256) ──────────────────
# Генерация: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=CHANGE_ME_fernet_key

# ── CORS ────────────────────────────────────────────────────────
CORS_ORIGINS=["https://taxrep.finitin.us"]

# ── OCR сервис (выберите один) ──────────────────────────────────
OCR_PROVIDER=yandex                       # yandex | google | aws
YANDEX_OCR_API_KEY=CHANGE_ME_if_used
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp_credentials.json
AWS_ACCESS_KEY_ID=CHANGE_ME_if_used
AWS_SECRET_ACCESS_KEY=CHANGE_ME_if_used
AWS_REGION=us-east-1

# ── Валютные курсы ──────────────────────────────────────────────
CBR_API_URL=https://www.cbr.ru/scripts/XML_daily.asp
OPEN_EXCHANGE_RATES_APP_ID=CHANGE_ME_if_used

# ── Email (уведомления) ─────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=noreply@taxrep.finitin.us

# ── Первый администратор (только при --first-run) ───────────────
# Telegram ID администратора (узнать через @userinfobot)
FIRST_ADMIN_TELEGRAM_ID=CHANGE_ME_your_telegram_id

# ── SSL / Certbot ───────────────────────────────────────────────
CERTBOT_EMAIL=CHANGE_ME_your_email@example.com
